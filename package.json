{
  "name": "openapi-semantic-validator",
  "version": "0.7.1",
  "description": "Perform structural and semantic validation on an OpenAPI specification, just like Swagger Editor!",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": "https://github.com/mhassan1/openapi-semantic-validator",
  "author": "mhassan1",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "src/**/*.js",
    "src/**/*.d.ts",
    "lib/**/*.js"
  ],
  "scripts": {
    "build": "node scripts/build.js && rm -f index.d.ts && tsc",
    "test": "eslint '**/*.ts' && yarn build && jest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.6.2",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "fs-extra": "^11.1.0",
    "jest": "^30.0.2",
    "swagger-editor-npm": "exec:./scripts/fetch-swagger-editor.js",
    "ts-jest": "^29.1.1",
    "typescript": "~5.8.3"
  },
  "dependenciesMeta": {
    "swagger-editor-npm": {
      "built": true
    },
    "unrs-resolver": {
      "built": true
    }
  },
  "_bundled": {
    "swagger-editor": "5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "packageManager": "yarn@4.16.0"
}
